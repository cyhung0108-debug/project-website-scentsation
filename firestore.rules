rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isMerchant() {
      return isSignedIn()
        && (
          request.auth.uid == "q03M83yAzAfFMnHRZBcvDusykMy2"
          || request.auth.uid == "bMUXPPo7KPX7bIL14fzCwvFExYG2"
        );
    }

    function merchantRoleData() {
      return get(/databases/$(database)/documents/merchantRoles/$(request.auth.uid)).data;
    }

    function hasPageEditorRole(roleData) {
      return (
          roleData.keys().hasAll(["role"])
          && roleData.role in ["merchant", "admin", "super_admin"]
        )
        || (
          roleData.keys().hasAll(["roleName"])
          && roleData.roleName in ["merchant", "admin", "super_admin"]
        );
    }

    function hasPageWritePermission(roleData) {
      return (
          roleData.keys().hasAll(["permissions"])
          && roleData.permissions is map
          && roleData.permissions.pagesWrite == true
        )
        || (
          roleData.keys().hasAll(["pagesWrite"])
          && roleData.pagesWrite == true
        );
    }

    function canWritePages() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/merchantRoles/$(request.auth.uid))
        && merchantRoleData().active == true
        && hasPageEditorRole(merchantRoleData())
        && hasPageWritePermission(merchantRoleData());
    }

    function canWriteSiteContent() {
      return isMerchant() || canWritePages();
    }

    function isHomeHeroPayload(data) {
      return data.keys().hasOnly([
          "type",
          "title",
          "subtitle",
          "imageUrl",
          "imagePath",
          "imageAlt",
          "buttonText",
          "buttonHref",
          "isActive",
          "updatedAt",
          "updatedBy"
        ])
        && data.type == "homeHero"
        && data.title is string
        && data.title.size() <= 120
        && data.subtitle is string
        && data.subtitle.size() <= 280
        && data.imageUrl is string
        && data.imageUrl.size() <= 2000
        && data.imagePath is string
        && data.imagePath.size() <= 500
        && data.imageAlt is string
        && data.imageAlt.size() <= 160
        && data.buttonText is string
        && data.buttonText.size() <= 60
        && data.buttonHref is string
        && data.buttonHref.size() <= 500
        && data.isActive is bool
        && data.updatedAt is timestamp
        && data.updatedBy is string
        && data.updatedBy == request.auth.uid;
    }

    function isFooterPayload(data) {
      return data.keys().hasOnly([
          "type",
          "logoText",
          "description",
          "phone",
          "email",
          "address",
          "copyright",
          "instagramUrl",
          "facebookUrl",
          "isActive",
          "updatedAt",
          "updatedBy"
        ])
        && data.type == "footer"
        && data.logoText is string
        && data.logoText.size() <= 80
        && data.description is string
        && data.description.size() <= 280
        && data.phone is string
        && data.phone.size() <= 60
        && data.email is string
        && data.email.size() <= 120
        && data.address is string
        && data.address.size() <= 280
        && data.copyright is string
        && data.copyright.size() <= 160
        && data.instagramUrl is string
        && data.instagramUrl.size() <= 500
        && data.facebookUrl is string
        && data.facebookUrl.size() <= 500
        && data.isActive is bool
        && data.updatedAt is timestamp
        && data.updatedBy is string
        && data.updatedBy == request.auth.uid;
    }

    function isContactPayload(data) {
      return data.keys().hasOnly([
          "type",
          "title",
          "subtitle",
          "address",
          "phone",
          "email",
          "openingHours",
          "googleMapEmbedUrl",
          "other",
          "isActive",
          "updatedAt",
          "updatedBy"
        ])
        && data.type == "contact"
        && data.title is string
        && data.title.size() <= 120
        && data.subtitle is string
        && data.subtitle.size() <= 240
        && data.address is string
        && data.address.size() <= 280
        && data.phone is string
        && data.phone.size() <= 60
        && data.email is string
        && data.email.size() <= 120
        && data.openingHours is string
        && data.openingHours.size() <= 160
        && data.googleMapEmbedUrl is string
        && data.googleMapEmbedUrl.size() <= 1000
        && data.other is string
        && data.other.size() <= 360
        && data.isActive is bool
        && data.updatedAt is timestamp
        && data.updatedBy is string
        && data.updatedBy == request.auth.uid;
    }

    function isAboutPayload(data) {
      return data.keys().hasOnly([
          "type",
          "title",
          "subtitle",
          "intro",
          "sectionTitle",
          "sectionContent",
          "imageUrl",
          "imageAlt",
          "isActive",
          "updatedAt",
          "updatedBy"
        ])
        && data.type == "about"
        && data.title is string
        && data.title.size() <= 120
        && data.subtitle is string
        && data.subtitle.size() <= 160
        && data.intro is string
        && data.intro.size() <= 600
        && data.sectionTitle is string
        && data.sectionTitle.size() <= 120
        && data.sectionContent is string
        && data.sectionContent.size() <= 800
        && data.imageUrl is string
        && data.imageUrl.size() <= 2000
        && data.imageAlt is string
        && data.imageAlt.size() <= 160
        && data.isActive is bool
        && data.updatedAt is timestamp
        && data.updatedBy is string
        && data.updatedBy == request.auth.uid;
    }

    match /merchantRoles/{userId} {
      allow read: if isOwner(userId) || isMerchant();
      allow create, update, delete: if false;
    }

    match /products/{productId} {
      allow read: if resource.data.isActive == true || isMerchant();
      allow create, update, delete: if isMerchant();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isMerchant();
    }

    match /users/{userId} {
      allow read, create, update, delete: if isOwner(userId);

      match /cart/{itemId} {
        allow read, create, update, delete: if isOwner(userId);
      }
    }

    match /orders/{orderId} {
      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid || isMerchant());
      allow create, update, delete: if isMerchant();
    }

    match /siteContent/{docId} {
      allow read: if true;
      allow create, update: if canWriteSiteContent()
        && (
          (docId == "home" && isHomeHeroPayload(request.resource.data))
          || (docId == "footer" && isFooterPayload(request.resource.data))
          || (docId == "contact" && isContactPayload(request.resource.data))
          || (docId == "about" && isAboutPayload(request.resource.data))
        );
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
