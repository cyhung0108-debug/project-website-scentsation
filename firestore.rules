rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function merchantRolePath() {
      return /databases/$(database)/documents/merchantRoles/$(request.auth.uid);
    }

    function isMerchant() {
      return isSignedIn()
        && exists(merchantRolePath())
        && get(merchantRolePath()).data.role == "merchant"
        && get(merchantRolePath()).data.active == true;
    }

    function canReadUsers() {
      return isMerchant()
        && get(merchantRolePath()).data.permissions.usersRead == true;
    }

    function canWriteUsers() {
      return isMerchant()
        && get(merchantRolePath()).data.permissions.usersWrite == true;
    }

    function canReadOrders() {
      return isMerchant()
        && get(merchantRolePath()).data.permissions.ordersRead == true;
    }

    function canWriteProducts() {
      return isMerchant()
        && get(merchantRolePath()).data.permissions.productsWrite == true;
    }

    match /products/{productId} {
      allow read: if resource.data.isActive == true || isMerchant();
      allow create, update, delete: if canWriteProducts();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if canWriteProducts();
    }

    match /merchantRoles/{userId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || canReadUsers();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || canWriteUsers();
      allow delete: if false;

      match /cart/{itemId} {
        allow read, create, update, delete: if isOwner(userId);
      }
    }

    match /orders/{orderId} {
      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid || canReadOrders());
      allow create, update, delete: if isMerchant();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
