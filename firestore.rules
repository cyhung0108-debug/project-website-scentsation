rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function userPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function invitePath(token) {
      return /databases/$(database)/documents/userInvites/$(token);
    }

    function merchantRolePath() {
      return /databases/$(database)/documents/merchantRoles/$(request.auth.uid);
    }

    function hasUserProfile() {
      return isSignedIn() && exists(userPath(request.auth.uid));
    }

    function legacyMerchantActive() {
      return isSignedIn()
        && exists(merchantRolePath())
        && get(merchantRolePath()).data.role == "merchant"
        && get(merchantRolePath()).data.active == true;
    }

    function currentUserRole() {
      return hasUserProfile() ? get(userPath(request.auth.uid)).data.role : (legacyMerchantActive() ? "super_admin" : "");
    }

    function currentUserStatus() {
      return hasUserProfile() ? get(userPath(request.auth.uid)).data.status : (legacyMerchantActive() ? "active" : "");
    }

    function isActiveUser() {
      return isSignedIn() && currentUserStatus() != "blocked";
    }

    function isSuperAdmin() {
      return isActiveUser() && currentUserRole() == "super_admin";
    }

    function isAdmin() {
      return isActiveUser() && currentUserRole() == "admin";
    }

    function isStaff() {
      return isActiveUser() && currentUserRole() == "staff";
    }

    function canAccessDashboard() {
      return isSuperAdmin() || isAdmin() || isStaff();
    }

    function canManageUsers() {
      return isSuperAdmin() || isAdmin();
    }

    function settingsPath() {
      return /databases/$(database)/documents/settings/rolePermissions;
    }

    function rolePermissionsDocExists() {
      return exists(settingsPath());
    }

    function settingsRoleFlag(feature, role) {
      return rolePermissionsDocExists()
        && get(settingsPath()).data.permissions[feature] is map
        && get(settingsPath()).data.permissions[feature][role] == true;
    }

    function canViewUserDetails() {
      return canManageUsers()
        || (
          isStaff()
          && (
            !rolePermissionsDocExists()
            || settingsRoleFlag("viewUserDetails", "staff")
          )
        );
    }

    function canManagePermissions() {
      return isSuperAdmin() || isAdmin();
    }

    function canManageProducts() {
      return isSuperAdmin() || isAdmin() || isStaff();
    }

    function canManagePages() {
      return isSuperAdmin() || isAdmin() || isStaff();
    }

    function canReadSales() {
      return isSuperAdmin() || isAdmin();
    }

    function validInvite(token, role) {
      return token is string
        && exists(invitePath(token))
        && get(invitePath(token)).data.email == request.auth.token.email
        && get(invitePath(token)).data.used == false
        && get(invitePath(token)).data.status == "pending"
        && get(invitePath(token)).data.role == role;
    }

    function validUserCreate(userId) {
      return isOwner(userId)
        && request.resource.data.uid == userId
        && request.resource.data.status == "active"
        && request.resource.data.keys().hasOnly([
          "uid", "email", "displayName", "providerId", "role", "status",
          "phone", "address", "gender", "birthday", "note", "tags",
          "createdAt", "lastLoginAt", "updatedAt", "inviteToken"
        ])
        && (
          request.resource.data.role == "customer"
          || (legacyMerchantActive() && request.resource.data.role == "super_admin")
          || validInvite(request.resource.data.inviteToken, request.resource.data.role)
        );
    }

    function validUserSelfUpdate(userId) {
      return isOwner(userId)
        && isActiveUser()
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.role == resource.data.role
        && request.resource.data.status == resource.data.status
        && request.resource.data.note == resource.data.note
        && request.resource.data.keys().hasOnly([
          "uid", "email", "displayName", "providerId", "role", "status",
          "phone", "address", "gender", "birthday", "note", "tags",
          "createdAt", "lastLoginAt", "updatedAt", "inviteToken"
        ]);
    }

    function validInviteUserUpdate(userId) {
      return isOwner(userId)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.status == "active"
        && validInvite(request.resource.data.inviteToken, request.resource.data.role)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "email", "displayName", "providerId", "role", "status", "inviteToken", "updatedAt"
        ]);
    }

    function validAdminUserUpdate() {
      return canManageUsers()
        && (
          isSuperAdmin()
          || (isAdmin() && !(resource.data.role in ["super_admin", "admin"]))
        )
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.providerId == resource.data.providerId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "displayName", "phone", "address", "birthday", "gender", "note", "tags", "updatedAt"
        ]);
    }

    function validStaffUserNoteUpdate() {
      return canViewUserDetails()
        && isStaff()
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.providerId == resource.data.providerId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.role == resource.data.role
        && request.resource.data.status == resource.data.status
        && request.resource.data.displayName == resource.data.displayName
        && request.resource.data.phone == resource.data.phone
        && request.resource.data.address == resource.data.address
        && request.resource.data.birthday == resource.data.birthday
        && request.resource.data.gender == resource.data.gender
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "note", "updatedAt"
        ]);
    }

    function validPermissionUpdate() {
      return canManagePermissions()
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.providerId == resource.data.providerId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "role", "status", "updatedAt"
        ])
        && (
          isSuperAdmin()
          || (
            isAdmin()
            && !(resource.data.role in ["super_admin", "admin"])
            && request.resource.data.role in ["staff", "customer"]
          )
        );
    }

    function validInviteCreate(token) {
      return canManageUsers()
        && request.resource.data.token == token
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.used == false
        && request.resource.data.status == "pending"
        && request.resource.data.email is string
        && (
          (isSuperAdmin() && request.resource.data.role in ["admin", "staff"])
          || (isAdmin() && request.resource.data.role in ["admin", "staff"])
        )
        && request.resource.data.keys().hasOnly([
          "email", "role", "token", "createdBy", "createdAt", "used", "status"
        ]);
    }

    function validInviteUse(token) {
      return isSignedIn()
        && resource.data.token == token
        && resource.data.email == request.auth.token.email
        && resource.data.used == false
        && resource.data.status == "pending"
        && request.resource.data.email == resource.data.email
        && request.resource.data.role == resource.data.role
        && request.resource.data.token == resource.data.token
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.used == true
        && request.resource.data.status == "used"
        && request.resource.data.usedBy == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "used", "status", "usedBy", "usedAt"
        ]);
    }

    function validInviteHideOrDelete(token) {
      return canManageUsers()
        && resource.data.token == token
        && request.resource.data.email == resource.data.email
        && request.resource.data.role == resource.data.role
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.used == resource.data.used
        && request.resource.data.status == "deleted"
        && request.resource.data.hidden == true
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status", "hidden", "deletedAt"
        ]);
    }

    function rolePermissionFeatureKeys() {
      return [
        "usersManage", "inviteUsers", "inviteRecords", "salesManage",
        "productsManage", "categoriesManage", "pagesManage", "permissionsManage",
        "storePreview", "usersBlock", "viewUserDetails", "usersRoleEdit", "usersProfileEdit",
        "ordersRead", "ordersUpdate"
      ];
    }

    function rolePermissionRoleKeys() {
      return ["super_admin", "admin", "staff", "customer"];
    }

    function validRolePermissionRow(row) {
      return row is map
        && row.keys().hasAll(rolePermissionRoleKeys())
        && row.keys().hasOnly(rolePermissionRoleKeys())
        && row.super_admin is bool
        && row.admin is bool
        && row.staff is bool
        && row.customer is bool;
    }

    function validRolePermissionDocument() {
      return request.resource.data.keys().hasOnly(["permissions", "updatedAt", "updatedBy"])
        && request.resource.data.permissions is map
        && request.resource.data.permissions.keys().hasAll(rolePermissionFeatureKeys())
        && request.resource.data.permissions.keys().hasOnly(rolePermissionFeatureKeys())
        && validRolePermissionRow(request.resource.data.permissions.usersManage)
        && validRolePermissionRow(request.resource.data.permissions.inviteUsers)
        && validRolePermissionRow(request.resource.data.permissions.inviteRecords)
        && validRolePermissionRow(request.resource.data.permissions.salesManage)
        && validRolePermissionRow(request.resource.data.permissions.productsManage)
        && validRolePermissionRow(request.resource.data.permissions.categoriesManage)
        && validRolePermissionRow(request.resource.data.permissions.pagesManage)
        && validRolePermissionRow(request.resource.data.permissions.permissionsManage)
        && validRolePermissionRow(request.resource.data.permissions.storePreview)
        && validRolePermissionRow(request.resource.data.permissions.usersBlock)
        && validRolePermissionRow(request.resource.data.permissions.viewUserDetails)
        && validRolePermissionRow(request.resource.data.permissions.usersRoleEdit)
        && validRolePermissionRow(request.resource.data.permissions.usersProfileEdit)
        && validRolePermissionRow(request.resource.data.permissions.ordersRead)
        && validRolePermissionRow(request.resource.data.permissions.ordersUpdate)
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.updatedBy == request.auth.uid;
    }

    function superAdminPermissionsAreTrue() {
      return request.resource.data.permissions.usersManage.super_admin == true
        && request.resource.data.permissions.inviteUsers.super_admin == true
        && request.resource.data.permissions.inviteRecords.super_admin == true
        && request.resource.data.permissions.salesManage.super_admin == true
        && request.resource.data.permissions.productsManage.super_admin == true
        && request.resource.data.permissions.categoriesManage.super_admin == true
        && request.resource.data.permissions.pagesManage.super_admin == true
        && request.resource.data.permissions.permissionsManage.super_admin == true
        && request.resource.data.permissions.storePreview.super_admin == true
        && request.resource.data.permissions.usersBlock.super_admin == true
        && request.resource.data.permissions.viewUserDetails.super_admin == true
        && request.resource.data.permissions.usersRoleEdit.super_admin == true
        && request.resource.data.permissions.usersProfileEdit.super_admin == true
        && request.resource.data.permissions.ordersRead.super_admin == true
        && request.resource.data.permissions.ordersUpdate.super_admin == true;
    }

    function superAdminPermissionsUnchanged() {
      return request.resource.data.permissions.usersManage.super_admin == resource.data.permissions.usersManage.super_admin
        && request.resource.data.permissions.inviteUsers.super_admin == resource.data.permissions.inviteUsers.super_admin
        && request.resource.data.permissions.inviteRecords.super_admin == resource.data.permissions.inviteRecords.super_admin
        && request.resource.data.permissions.salesManage.super_admin == resource.data.permissions.salesManage.super_admin
        && request.resource.data.permissions.productsManage.super_admin == resource.data.permissions.productsManage.super_admin
        && request.resource.data.permissions.categoriesManage.super_admin == resource.data.permissions.categoriesManage.super_admin
        && request.resource.data.permissions.pagesManage.super_admin == resource.data.permissions.pagesManage.super_admin
        && request.resource.data.permissions.permissionsManage.super_admin == resource.data.permissions.permissionsManage.super_admin
        && request.resource.data.permissions.storePreview.super_admin == resource.data.permissions.storePreview.super_admin
        && request.resource.data.permissions.usersBlock.super_admin == resource.data.permissions.usersBlock.super_admin
        && request.resource.data.permissions.viewUserDetails.super_admin == resource.data.permissions.viewUserDetails.super_admin
        && request.resource.data.permissions.usersRoleEdit.super_admin == resource.data.permissions.usersRoleEdit.super_admin
        && request.resource.data.permissions.usersProfileEdit.super_admin == resource.data.permissions.usersProfileEdit.super_admin
        && request.resource.data.permissions.ordersRead.super_admin == resource.data.permissions.ordersRead.super_admin
        && request.resource.data.permissions.ordersUpdate.super_admin == resource.data.permissions.ordersUpdate.super_admin;
    }

    function validRolePermissionsCreate() {
      return validRolePermissionDocument()
        && (
          isSuperAdmin()
          || (isAdmin() && superAdminPermissionsAreTrue())
        );
    }

    function validRolePermissionsUpdate() {
      return validRolePermissionDocument()
        && (
          isSuperAdmin()
          || (isAdmin() && superAdminPermissionsUnchanged())
        );
    }

    function validOrderOwnerRead() {
      return isSignedIn()
        && (
          resource.data.customerUid == request.auth.uid
          || resource.data.userId == request.auth.uid
          || (
            request.auth.token.email != null
            && resource.data.customerEmail == request.auth.token.email
          )
        );
    }

    function validOrderCustomerCreate() {
      return isSignedIn()
        && isActiveUser()
        && request.resource.data.customerUid == request.auth.uid
        && request.resource.data.status == "pending"
        && request.resource.data.paymentMethod == "credit_card"
        && request.resource.data.paymentStatus == "mock_paid"
        && request.resource.data.createdAt == request.time
        && request.resource.data.keys().hasOnly([
          "orderNumber", "customerUid", "customerEmail", "customerName", "customerPhone",
          "recipientName", "recipientPhone", "deliveryMethod", "deliveryAddress",
          "items", "subtotal", "discount", "shippingFee", "extraFee", "total",
          "paymentMethod", "paymentStatus", "status", "note", "createdAt"
        ]);
    }

    function validOrderMerchantUpdate() {
      return canReadSales()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status", "merchantNote", "updatedAt"
        ]);
    }

    match /products/{productId} {
      allow read: if resource.data.isActive == true || canAccessDashboard();
      allow create, update, delete: if canManageProducts();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if canManageProducts();
    }

    match /siteContent/{docId} {
      allow read: if true;
      allow create, update, delete: if canManagePages();
    }

    match /merchantRoles/{userId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || canViewUserDetails();
      allow create: if validUserCreate(userId);
      allow update: if validUserSelfUpdate(userId) || validInviteUserUpdate(userId) || validAdminUserUpdate() || validStaffUserNoteUpdate() || validPermissionUpdate();
      allow delete: if false;

      match /cart/{itemId} {
        allow read, create, update, delete: if isOwner(userId) && isActiveUser();
      }
    }

    match /userInvites/{token} {
      allow read: if canManageUsers()
        || (resource.data.used == false && resource.data.status == "pending");
      allow create: if validInviteCreate(token);
      allow update: if validInviteUse(token) || validInviteHideOrDelete(token);
      allow delete: if false;
    }

    match /settings/{docId} {
      allow read: if docId == "rolePermissions" && canAccessDashboard();
      allow create: if docId == "rolePermissions" && validRolePermissionsCreate();
      allow update: if docId == "rolePermissions" && validRolePermissionsUpdate();
      allow delete: if false;
    }

    match /orders/{orderId} {
      allow read: if validOrderOwnerRead() || canReadSales();
      allow create: if validOrderCustomerCreate() || canReadSales();
      allow delete: if canReadSales();
      allow update: if validOrderMerchantUpdate();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
