rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isMerchant() {
      return isSignedIn()
        && (
          request.auth.uid == "q03M83yAzAfFMnHRZBcvDusykMy2"
          || request.auth.uid == "bMUXPPo7KPX7bIL14fzCwvFExYG2"
        );
    }

    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if isMerchant()
        && (request.resource == null
          || (request.resource.size < 10 * 1024 * 1024
            && request.resource.contentType.matches('image/.*')));
    }

    match /site-content/{allPaths=**} {
      allow read: if true;
      // TODO: Replace hardcoded merchant UIDs with custom claims or a default
      // database role mirror before removing the transition access model.
      allow write: if isMerchant()
        && (request.resource == null
          || (request.resource.size < 10 * 1024 * 1024
            && request.resource.contentType.matches('image/.*')));
    }

    match /users/{userId}/{allPaths=**} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if isSignedIn()
        && request.auth.uid == userId
        && (request.resource == null
          || (request.resource.size < 5 * 1024 * 1024
            && request.resource.contentType.matches('image/.*')));
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
